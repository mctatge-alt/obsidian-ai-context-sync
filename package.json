{
	"name": "obsidian-ai-context-sync",
	"version": "1.0.0",
	"description": "Obsidian plugin to sync AI context across Claude, Cursor, and other AI coding assistants",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"ai",
		"claude",
		"cursor",
		"context",
		"llm",
		"gpt",
		"coding-assistant"
	],
	"author": "Mitchell Tatge",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.20.0",
		"obsidian": "latest",
		"tslib": "^2.6.2",
		"typescript": "^5.3.3"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/mitchelltatge/obsidian-ai-context-sync.git"
	}
}
